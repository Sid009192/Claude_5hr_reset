# Copy this file to ".env" and fill in your own values. .env is gitignored.
# bot_token: create a bot via @BotFather -> /newbot, copy the HTTP API token.
# chat_id:   message your bot once, then ask @userinfobot for your numeric Id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Calendar OAuth (Desktop app credentials from Google Cloud Console).
# APIs & Services -> Credentials -> your OAuth 2.0 Client ID (Desktop).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
